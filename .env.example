# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── Supabase (used for Edge-side rate limiting via PostgREST RPC) ─────
# Find these in: Supabase Dashboard → Project Settings → API
# - URL:        "Project URL"  (e.g. https://xyzcompany.supabase.co)
#               Acceptable as either SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL
#               (the URL itself is not secret).
# - Key:        "service_role" secret (NOT the anon key — bypasses RLS)
#               MUST be server-side only (NEVER use NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Cloudinary (image uploads) ────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Auth ──────────────────────────────────────────────────────────────
# REQUIRED in production — app crashes on startup if missing.
# Generate with:  openssl rand -base64 48
JWT_SECRET=generate-a-32+char-random-string-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Email (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="Aura Living <noreply@auraliving.com>"

# ── Site URL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aura-living-1.vercel.app

# ── Cron jobs (Vercel cron auth) ──────────────────────────────────────
CRON_SECRET=generate-a-random-string-here

# ── Analytics (optional) ──────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxxxx
