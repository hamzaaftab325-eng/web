# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log

# Baseline TypeScript snapshot (for diffing during production-hardening)
.baseline-tsc.log

# Husky internals (only the hooks themselves are committed)
.husky/_/

# Playwright test artifacts
/test-results/
/playwright-report/
/playwright/.cache/

# Bundle analyzer output
/.analyze/

# Skills directory
/skills/
# Internal tooling
.zscripts/
# Junk files
tool-results/
/upload/
public/upload/
# Lockfile (project uses bun.lock)
package-lock.json
